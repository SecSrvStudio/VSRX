{
    "name": "vsrx",
    "displayName": "VSRX",
    "description": "VS Roblox Executor - Run Lua scripts seamlessly across all executors using Visual Studio Code.",
    "publisher": "VSRX-Roblox",
    "version": "1.0.44",
    "engines": {
        "vscode": "^1.74.0"
    },
    "icon": "resources/VSRX.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/7yd7/VSRX.git"
    },
    "homepage": "https://github.com/7yd7/VSRX",
    "bugs": {
        "url": "https://github.com/7yd7/VSRX/issues"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:lua",
        "onLanguage:luau",
        "onCommand:vsrx.showClients",
        "onCommand:vsrx.runScript",
        "onCommand:vsrx.saveScript",
        "onCommand:vsrx.showSavedScripts",
        "onCommand:vsrx.showScriptHub"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "vsrx.runScript",
                "title": "VSRX: Run Script",
                "icon": "$(play)"
            },
            {
                "command": "vsrx.saveScript",
                "title": "VSRX: Save Script to File",
                "icon": "$(save)"
            },
            {
                "command": "vsrx.showSavedScripts",
                "title": "VSRX: Save (Browse)",
                "icon": "$(folder)"
            },
            {
                "command": "vsrx.showScriptHub",
                "title": "VSRX: Hub",
                "icon": "$(cloud-download)"
            },
            {
                "command": "vsrx.showClients",
                "title": "VSRX: Manage Clients"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "vsrx.runScript",
                    "group": "navigation@1"
                },
                {
                    "command": "vsrx.saveScript",
                    "group": "navigation@2"
                }
            ]
        },
        "keybindings": [
            {
                "command": "vsrx.runScript",
                "key": "f5",
                "mac": "f5",
                "when": "editorTextFocus && (editorLangId == lua || editorLangId == luau)"
            }
        ],
        "configuration": {
            "title": "VSRX",
            "properties": {
                "vsrx.showNotifications": {
                    "type": "boolean",
                    "default": true,
                    "description": "[UI] Show info notifications when executing or saving scripts."
                },
                "vsrx.showSaveButton": {
                    "type": "boolean",
                    "default": true,
                    "description": "[UI] Show the 'Save' shortcut on the Status Bar."
                },
                "vsrx.showHubButton": {
                    "type": "boolean",
                    "default": true,
                    "description": "[UI] Show the 'Hub' shortcut on the Status Bar."
                },
                "vsrx.enableConsoleCapture": {
                    "type": "boolean",
                    "default": true,
                    "description": "[Console] Completely Enable/Disable live Roblox log capture. Use this to reduce network usage or lag."
                },
                "vsrx.enableInternalUI": {
                    "type": "boolean",
                    "default": false,
                    "description": "[Roblox] Enable the Iris-based (ImGui) internal UI menu for management inside Roblox."
                },
                "vsrx.showUIOnLoad": {
                    "type": "boolean",
                    "default": false,
                    "description": "[Roblox] Automatically show the internal UI when the loader script runs (instead of waiting for F1)."
                },
                "vsrx.defaultSavePath": {
                    "type": "string",
                    "default": "",
                    "description": "[Scripts] The default directory where your VSRX scripts are saved. Used for both saving and the In-Game browser."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "typescript": "^4.9.3"
    }
}