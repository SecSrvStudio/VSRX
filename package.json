{
    "name": "vsrx",
    "displayName": "VSRX",
    "description": "VS Roblox Executor - Run Lua scripts seamlessly across all executors using Visual Studio Code.",
    "version": "1.0.3",
    "engines": {
        "vscode": "^1.74.0"
    },
    "publisher": "7yd7",
    "icon": "resources/VSRX.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/7yd7/VSRX"
    },
    "homepage": "https://github.com/7yd7/VSRX",
    "bugs": {
        "url": "https://github.com/7yd7/VSRX/issues"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:lua",
        "onLanguage:luau",
        "onCommand:vsrx.showClients",
        "onCommand:vsrx.runScript",
        "onCommand:vsrx.saveScript",
        "onCommand:vsrx.showSavedScripts"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "vsrx.runScript",
                "title": "VSRX: Run Script",
                "icon": "$(play)"
            },
            {
                "command": "vsrx.saveScript",
                "title": "VSRX: Save Script",
                "icon": "$(save)"
            },
            {
                "command": "vsrx.showSavedScripts",
                "title": "VSRX: Saved Scripts",
                "icon": "$(folder)"
            },
            {
                "command": "vsrx.showClients",
                "title": "VSRX: Manage Clients"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "vsrx.runScript",
                    "group": "navigation@1"
                },
                {
                    "command": "vsrx.saveScript",
                    "group": "navigation@2"
                }
            ]
        },
        "keybindings": [
            {
                "command": "vsrx.runScript",
                "key": "f5",
                "mac": "f5",
                "when": "editorTextFocus && (editorLangId == lua || editorLangId == luau)"
            }
        ],
        "configuration": {
            "title": "VSRX",
            "properties": {
                "vsrx.defaultSavePath": {
                    "type": "string",
                    "default": "",
                    "description": "Default absolute folder path to save scripts when clicking the Save button. If left empty, a save dialog will always open."
                },
                "vsrx.showNotifications": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show info notifications when executing or saving scripts."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "typescript": "^4.9.3"
    }
}