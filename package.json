{
    "name": "vsrx",
    "displayName": "VSRX",
    "description": "VS Roblox Executor - Run Lua scripts seamlessly across all executors using Visual Studio Code.",
    "version": "1.0.1",
    "engines": {
        "vscode": "^1.74.0"
    },
    "publisher": "7yd7",
    "icon": "resources/VSRX.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/7yd7/VSRX"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:lua",
        "onLanguage:luau",
        "onCommand:vsrx.showClients",
        "onCommand:vsrx.runScript"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "vsrx.runScript",
                "title": "VSRX: Run Script",
                "icon": "$(play)"
            },
            {
                "command": "vsrx.showClients",
                "title": "VSRX: Manage Clients"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "vsrx.runScript",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "typescript": "^4.9.3"
    }
}